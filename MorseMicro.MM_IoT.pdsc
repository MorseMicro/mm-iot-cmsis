<?xml version="1.0" ?>
<package xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" schemaVersion="1.7.7" xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/Open-CMSIS-Pack/Open-CMSIS-Pack-Spec/v1.7.7/schema/PACK.xsd">
  <vendor>MorseMicro</vendor>
  <name>MM_IoT</name>
  <description>MorseMicro IoT Software Package</description>
  <url/>
  <supportContact/>
  <license>Docs/license.txt</license>
  <releases>
    <release version="1.9.0" date="2026-03-24">
        - Updating MM-IoT-SDK version to 2.11.0.
        - This change includes compiling libmorse from source instead of linking against a precompiled static library.
    </release>
    <release version="1.8.4" date="2026-03-09">
		- Updating MM-IoT-SDK version to 2.10.4.
    </release>
    <release version="1.8.3" date="2026-02-10">
		- Fix bugs in EKH05-Demo dependencies
		- Ensure correct board types print in UART/CLIs
    </release>
    <release version="1.8.2" date="2026-02-05">
		- Updating FreeRTOS+TCP module to build correctly, and marking as deprecated. This will be dropped by MM-IoT-SDK in next release.
		- Fix bugs in EKH05-Demo application logging to web console.
    </release>
    <release version="1.8.1" date="2026-02-04">
		- Updating build files to remove the need for changing build defines when changing applications.
		- Ensure UART logging and/or UART HAL with logging disabled is correctly chosen for example applications.
		- Updating dependencies for scan example application.
    </release>
    <release version="1.8.0" date="2026-01-29">
		- Updating MM-IoT-SDK version to 2.10.3.
		- Releasing updates for the EKH05-Demo app, including CLI support.
    </release>
    <release version="1.7.4" date="2025-10-03">
        -Updating MM-IoT-SDK version to 2.9.7.
    </release>
    <release version="1.7.3" date="2025-09-25">
        -Updating MM-IoT-SDK version to 2.9.6.
        -fix minor html bug.
    </release>
    <release version="1.7.2" date="2025-09-01">
        -Add cli example.
    </release>
    <release version="1.7.1" date="2025-08-21">
        -Option to remove HaLow connectivity from EKH05-Demo.
        -Less random BLE UUIDs.
        -Bug fixes:
          -Fix examples' issue with FreeRTOS-Plus-TCP.
          -Fix aws-iot example.
          -Fix rf-test example.
          -Minor bugs.
    </release>
    <release version="1.7.0" date="2025-07-11">
        -Updating the integrated MM-IoT-SDK version to 2.9.1
        -Add Region selection using ble attributes.
        -Accept FreeRTOS from a different pack.
        -Bug fixes:
          -Busy pin initial state in porting assistant.
    </release>
    <release version="1.6.0" date="2025-02-18">
        -Updating the integrated MM-IoT-SDK version to 2.8.2.
        -Add MM8108 chip support.
        -Add cortex-M4 and M7 libs.
        -Add hardware shim layer template.
        -Add Iperf to EKH05-Demo example.
        -Add mDNS to EKH05-Demo example.
        -Change mmconfig component to use MM-IoT-SDK mmconfig and add CONFIG partition.
        -Bug fixes:
          -Fix saved image endpoint url.
          -Add mm_app_common dependency to rftest and mqtt demo examples, too.
          -Make the Morse firmware and bcf arrays &quot;const&quot;.
    </release>
    <release version="1.5.1" date="2025-02-18">
        -Update License in source codes.
        -Set default ping.post_ping_delay_ms to 60000ms.
    </release>
    <release version="1.5.0" date="2025-01-31">
        -Add SDIO project.
        -Updated sslclient example certificates and fixed issues.
    </release>
    <release version="1.4.0" date="2025-01-21">
        -Updating the integrated MM-IoT-SDK version to 2.6.4.
        -EKH05-Demo example: can save the camera photo to the serial flash on the board.
    </release>
    <release version="1.3.4" date="2024-12-11">
        -Remove unused content that were blocking STM32CubeIDE to import this pack.
    </release>
    <release version="1.3.3" date="2024-11-15">
        -Update RegDB to match the new BCFs.
    </release>
    <release version="1.3.2" date="2024-11-14">
        -Update BCFs
    </release>
    <release version="1.3.1" date="2024-10-30">
        -Fix power waste through ADC
        -Add wnm_sleep_duration_ms to default configurations
    </release>
    <release version="1.3.0" date="2024-10-24">
        -Add ping capability to Demo example UI
        -Show IP info in a BLE attribute
        -Remove  BCF disabled channels from regdb
        -Fix CAM_PWDN default value
        -Fix red LED for EKH05 v3
        -Fix broken link to MorseMicro.com on the EKH05-Demo page
    </release>
    <release version="1.2.1" date="2024-10-04">
        -Fix broken pack 1.2.0
    </release>
    <release version="1.2.0" date="2024-10-04">
        -Auto select BCF based on VFEM
        -Auto detect Accelerometer sensor address
        -using correct version for each non-morse component
    </release>
    <release version="1.1.0" date="2024-09-27">
        -Selecting BCF based on VFEM voltage
        -Auto detect IIS328DQ address
    </release>
    <release version="1.0.0" date="2024-09-20">
        Initial version
    </release>
  </releases>
  <conditions>
    <condition id="Cortex-M33 condition">
      <description>CortexM33 core</description>
      <require Dcore="Cortex-M33"/>
      <require Dfpu="FPU"/>
    </condition>
    <condition id="Cortex-M4 condition">
      <description>CortexM4 core</description>
      <require Dcore="Cortex-M4"/>
      <require Dfpu="FPU"/>
    </condition>
    <condition id="Cortex-M7 condition">
      <description>CortexM7 core</description>
      <require Dcore="Cortex-M7"/>
      <require Dfpu="FPU"/>
    </condition>
    <condition id="Little-endian condition">
      <description>Mandating Little-endianness</description>
      <require Dendian="Little-endian"/>
    </condition>
    <condition id="MMx108-template conditions">
      <description>MMx108-template condition</description>
      <require Cclass="MM_IoT" Cgroup="mmutils"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <deny Cclass="MM_IoT" Cgroup="BSP-EKH05" Csub="MMx108"/>
    </condition>
    <condition id="need HW shim condition">
      <description>Mandating precense of one hardware shim layer</description>
      <accept Cclass="MM_IoT" Cgroup="BSP-EKH05" Csub="MMx108"/>
      <accept Cclass="MM_IoT" Cgroup="MMx108-template"/>
    </condition>
    <condition id="RTOS conditions set-1">
      <description>Require RTOS conditions set 1</description>
      <require Cclass="CMSIS" Cgroup="RTOS2" Csub="Core"/>
      <require Cclass="CMSIS" Cgroup="RTOS2" Csub="Heap" Cvariant="Heap_4"/>
    </condition>
    <condition id="RTOS conditions set-2">
      <description>Require RTOS conditions set 2</description>
      <require Cclass="CMSIS" Cgroup="RTOS2" Csub="FreeRTOS"/>
      <require Cclass="CMSIS" Cgroup="RTOS2" Csub="Heap" Cvariant="Heap_4"/>
    </condition>
    <condition id="MorseLib source files condition">
      <description>RTOS and HS shim dependencies for morselib</description>
      <accept condition="RTOS conditions set-1"/>
      <accept condition="RTOS conditions set-2"/>
      <require condition="need HW shim condition"/>
      <require Cclass="MM_IoT" Cgroup="morsefirmware"/>
      <require Cclass="MM_IoT" Cgroup="hostap"/>
    </condition>
    <condition id="MM_IoT mm_app_common conditions">
      <description>mm_app_common dependencies.</description>
      <require Cclass="MM_IoT" Cgroup="mmipal"/>
      <require Cclass="MM_IoT" Cgroup="mmconfig"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <require Cclass="MM_IoT" Cgroup="mmregdb"/>
    </condition>
    <condition id="MM_IoT mmconfig conditions">
      <description>mmconfig dependencies.</description>
      <require Cclass="MM_IoT" Cgroup="mmipal"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT mmipal conditions">
      <description>mmipal dependencies.</description>
      <accept Cclass="MM_IoT" Cgroup="mmLwIP"/>
      <require Cclass="MM_IoT" Cgroup="mmutils"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <require Cclass="MM_IoT" Cgroup="mmpktmem"/>
    </condition>
    <condition id="MM_IoT mmiperf conditions">
      <description>mmiperf dependencies.</description>
      <accept Cclass="MM_IoT" Cgroup="mmLwIP"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT mmpktmem conditions">
      <description>mmpktmem dependencies.</description>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT mmregdb conditions">
      <description>mmregdb dependencies.</description>
    </condition>
    <condition id="MM_IoT mmutils conditions">
      <description>mmutils dependencies.</description>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT hostap conditions">
      <description>hostap dependencies. </description>
      <require Cclass="MM_IoT" Cgroup="mbedtls"/>
    </condition>
    <condition id="MM_IoT mmagic conditions">
      <description>mmagic dependencies.</description>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <require Cclass="MM_IoT" Cgroup="mbedtls"/>
      <require Cclass="MM_IoT" Cgroup="slip"/>
      <require Cclass="MM_IoT" Cgroup="mmiperf"/>
      <require Cclass="MM_IoT" Cgroup="mmping"/>
      <require Cclass="MM_IoT" Cgroup="mmipal"/>
      <require Cclass="MM_IoT" Cgroup="mmpktmem"/>
      <require Cclass="MM_IoT" Cgroup="mmconfig"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="backoffAlgorithm"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="freertos-libs-common"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreJSON"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreSNTP"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreMQTT"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreMQTT-Agent"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="mqtt-agent-task"/>
    </condition>
    <condition id="MM_IoT mmping conditions">
      <description>mmping dependencies.</description>
      <accept Cclass="MM_IoT" Cgroup="mmLwIP"/>
    </condition>
    <condition id="MMx108-SPI Low Level Driver conditions">
      <description>MM6108 or MM8108 SPI Low Level Driver conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmutils"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <deny Cclass="MM_IoT" Cgroup="MMx108-template"/>
    </condition>
    <condition id="MMx108-SDIO Low Level Driver conditions">
      <description>MM6108 or MM8108 SDIO Low Level Driver conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmutils"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <deny Cclass="MM_IoT" Cgroup="MMx108-template"/>
    </condition>
    <condition id="MM_IoT mmLwIP conditions">
      <description>mmLwIP dependencies.</description>
      <require Cclass="MM_IoT" Cgroup="mmutils"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT IP_STACK condition">
      <description>Need one of MM_IoT's IP stacks.</description>
      <accept Cclass="MM_IoT" Cgroup="mmLwIP"/>
    </condition>
    <condition id="require MM_IoT mmLwIP condition">
      <description>Mandating MM_IoT mmLwIP</description>
      <accept Cclass="MM_IoT" Cgroup="mmLwIP"/>
    </condition>
    <condition id="require FreeRTOS-Libs coreSNTP condition">
      <description>Mandating FreeRTOS-Libs coreSNTP</description>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreSNTP"/>
    </condition>
    <condition id="require MM_IoT mmLwIP and FreeRTOS-Libs coreSNTP condition">
      <description>Mandating MM_IoT mmLwIP and FreeRTOS-Libs coreSNTP</description>
      <accept Cclass="MM_IoT" Cgroup="mmLwIP"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreSNTP"/>
    </condition>
    <condition id="MM_IoT iperf example conditions">
      <description>MM_IoT iperf example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmiperf"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT ping example conditions">
      <description>MM_IoT ping example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmping"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT wnm_sleep example conditions">
      <description>MM_IoT wnm_sleep example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmping"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT SHT4x conditions">
      <description>MM_IoT SHT4x conditions.</description>
    </condition>
    <condition id="MM_IoT W25Q16JV conditions">
      <description>MM_IoT W25Q16JV conditions.</description>
    </condition>
    <condition id="MM_IoT IIS328DQ conditions">
      <description>MM_IoT IIS328DQ conditions.</description>
    </condition>
    <condition id="MM_IoT OV5640 conditions">
      <description>MM_IoT OV5640 conditions.</description>
    </condition>
    <condition id="MM_IoT EKH05 Demo example conditions">
      <description>MM_IoT EKH05 Demo example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmLwIP"/>
      <require Cclass="MM_IoT" Cgroup="mmping"/>
      <require Cclass="MM_IoT" Cgroup="mmiperf"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <require Cclass="MM_IoT" Cgroup="mmagic"/>
      <require Cclass="MM_IoT" Cgroup="littlefs"/>
      <require Cclass="MM_IoT" Cgroup="BSP-EKH05" Csub="BSP"/>
      <require Cclass="MM_IoT" Cgroup="BSP-EKH05" Csub="SHT4x"/>
      <require Cclass="MM_IoT" Cgroup="BSP-EKH05" Csub="W25Q16JV"/>
      <require Cclass="MM_IoT" Cgroup="BSP-EKH05" Csub="IIS328DQ"/>
      <require Cclass="MM_IoT" Cgroup="BSP-EKH05" Csub="OV5640"/>
    </condition>
    <condition id="MM_IoT aws_iot example conditions">
      <description>MM_IoT aws_iot example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mbedtls"/>
      <require Cclass="MM_IoT" Cgroup="mm-tinycbor"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="backoffAlgorithm"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="freertos-libs-common"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreJSON"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreMQTT"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreMQTT-Agent"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreSNTP"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="mqtt-agent-task"/>
      <require Cclass="AWS" Cgroup="AWS-Shadow"/>
      <require Cclass="AWS" Cgroup="AWS-Fleet-Provisioning"/>
      <require Cclass="AWS" Cgroup="AWS-common"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT mqttdemo example conditions">
      <description>MM_IoT MQTT Demo example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mbedtls"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="freertos-libs-common"/>
      <require Cclass="FreeRTOS-Libs" Cgroup="coreMQTT"/>
    </condition>
    <condition id="MM_IoT sslclient example conditions">
      <description>MM_IoT SSL Client example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mbedtls"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT rftest application conditions">
      <description>MM_IoT rf-test application conditions.</description>
      <require Cclass="MM_IoT" Cgroup="slip"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
    </condition>
    <condition id="MM_IoT porting assistant example conditions">
      <description>MM_IoT porting assistant example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmutils"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
    </condition>
    <condition id="MM_IoT cli application conditions">
      <description>MM_IoT cli application conditions.</description>
      <require Cclass="MM_IoT" Cgroup="littlefs"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
      <require Cclass="MM_IoT" Cgroup="mmagic"/>
      <require Cclass="MM_IoT" Cgroup="morselib"/>
      <require Cclass="MM_IoT" Cgroup="mmregdb"/>
    </condition>
    <condition id="MM_IoT scan example conditions">
      <description>MM_IoT scan example conditions.</description>
      <require Cclass="MM_IoT" Cgroup="mmconfig"/>
      <require Cclass="MM_IoT" Cgroup="mm_app_common"/>
    </condition>
  </conditions>
  <taxonomy>
    <description Cclass="Board Support">Board Support</description>
    <description Cclass="MM_IoT">MorseMicro IoT Software Package</description>
  </taxonomy>
  <keywords>
    <keyword>MorseMicro</keyword>
  </keywords>
  <examples>
    <example name="HaLow_example_EKH05_SPI" doc="Abstract.txt" folder="HaLow_example_spi">
      <description>A HaLow Example Running on EKH05 dev kit.</description>
      <board name="EKH05" vendor="MorseMicro"/>
      <project>
        <environment name="cube" load="HaLow_example_spi.ioc"/>
      </project>
      <attributes>
        <component Cclass="MM_IoT" Cgroup="mm_app_common"/>
        <component Cclass="MM_IoT" Cgroup="mmconfig"/>
        <component Cclass="MM_IoT" Cgroup="mmipal"/>
        <component Cclass="MM_IoT" Cgroup="mmiperf"/>
        <component Cclass="MM_IoT" Cgroup="Example" Cvariant="iperf"/>
        <component Cclass="MM_IoT" Cgroup="mmutils"/>
        <component Cclass="MM_IoT" Cgroup="morselib"/>
        <component Cclass="MM_IoT" Cgroup="mmLwIP"/>
        <component Cclass="MM_IoT" Cgroup="hostap"/>
        <component Cclass="Board Support" Cgroup="EKH05" Cvariant="SPI"/>
      </attributes>
    </example>
    <example name="HaLow_example_EKH05_SDIO" doc="Abstract.txt" folder="HaLow_example_sdio">
      <description>A HaLow Example Running on EKH05 dev kit.</description>
      <board name="EKH05" vendor="MorseMicro"/>
      <project>
        <environment name="cube" load="HaLow_example_sdio.ioc"/>
      </project>
      <attributes>
        <component Cclass="MM_IoT" Cgroup="mm_app_common"/>
        <component Cclass="MM_IoT" Cgroup="mmconfig"/>
        <component Cclass="MM_IoT" Cgroup="mmipal"/>
        <component Cclass="MM_IoT" Cgroup="mmiperf"/>
        <component Cclass="MM_IoT" Cgroup="Example" Cvariant="iperf"/>
        <component Cclass="MM_IoT" Cgroup="mmutils"/>
        <component Cclass="MM_IoT" Cgroup="morselib"/>
        <component Cclass="MM_IoT" Cgroup="mmLwIP"/>
        <component Cclass="MM_IoT" Cgroup="hostap"/>
        <component Cclass="Board Support" Cgroup="EKH05" Cvariant="SPI"/>
      </attributes>
    </example>
  </examples>
  <components>
    <bundle Cbundle="MM_IoT" Cclass="MM_IoT" Cversion="2.11.2">
      <description>Morse Micro Software Components</description>
      <doc>https://www.morsemicro.com</doc>
      <component Cgroup="morsefirmware">
        <description>This component contains BCF and firmware files to load onto Morse chip at runtime</description>
        <files>
          <file category="source" name="morsefirmware/bcf_aw_hm593.c"/>
          <file category="source" name="morsefirmware/bcf_aw_hm593_4v3.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0801.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0802.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0805.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0806.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0a01.c"/>
          <file category="source" name="morsefirmware/bcf_ekh04_v6.c"/>
          <file category="source" name="morsefirmware/bcf_fgm100mabmd.c"/>
          <file category="source" name="morsefirmware/bcf_mf08651_jp.c"/>
          <file category="source" name="morsefirmware/bcf_mf08651_us.c"/>
          <file category="source" name="morsefirmware/bcf_mf16858.c"/>
          <file category="source" name="morsefirmware/bcf_mf28551.c"/>
          <file category="source" name="morsefirmware/bcf_mm_hl1.c"/>
          <file category="source" name="morsefirmware/bcf_mm_hl1_4v3.c"/>
          <file category="source" name="morsefirmware/bcf_sx_sdmah.c"/>
          <file category="source" name="morsefirmware/fw_mm6108.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0804.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0807.c"/>
          <file category="source" name="morsefirmware/bcf_boardtype_0a02.c"/>
          <file category="source" name="morsefirmware/bcf_mf15457.c"/>
          <file category="source" name="morsefirmware/fw_mm8108b2-rl.c"/>
          <file category="source" name="morsefirmware/shim_freertos/hooks.c"/>
          <file category="source" name="morsefirmware/shim_freertos/mm_logging.c"/>
          <file category="source" name="morsefirmware/shim_freertos/mmosal_shim_freertos.c"/>
          <file category="source" name="morsefirmware/shim_freertos/realloc.c"/>
          <file category="source" name="morsefirmware/shim_freertos/gettimeofday.c"/>
          <file category="source" name="morsefirmware/shim_freertos/mmhal_wlan_binaries.c"/>
        </files>
      </component>
      <component Cgroup="hostap" condition="MM_IoT hostap conditions">
        <description>This component provides wpa_supplicant for station side comms in a 802.11ah connection</description>
        <files>
          <file category="source" name="hostap/hostap/src/utils/common.c"/>
          <file category="source" name="hostap/hostap/src/crypto/aes-ctr.c"/>
          <file category="source" name="hostap/hostap/wpa_supplicant/eap_register.c"/>
          <file category="source" name="hostap/hostap/src/common/sae.c"/>
          <file category="source" name="hostap/hostap/wpa_supplicant/op_classes.c"/>
          <file category="source" name="hostap/hostap/morse_stubs.c"/>
          <file category="source" name="hostap/hostap/src/eapol_supp/eapol_supp_sm.c"/>
          <file category="source" name="hostap/hostap/wpa_supplicant/bgscan.c"/>
          <file category="source" name="hostap/hostap/src/crypto/tls_none.c"/>
          <file category="source" name="hostap/hostap/src/utils/bitfield.c"/>
          <file category="source" name="hostap/hostap/src/crypto/dh_groups.c"/>
          <file category="source" name="hostap/hostap/wpa_supplicant/events.c"/>
          <file category="source" name="hostap/hostap/wpa_supplicant/bgscan_simple.c"/>
          <file category="source" name="hostap/hostap/wpa_supplicant/wpas_glue.c"/>
          <file category="source" name="hostap/hostap/wpa_supplicant/autoscan.c"/>
          <file category="source" name="hostap/hostap/src/common/ptksa_cache.c"/>
