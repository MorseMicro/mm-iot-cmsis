          <file category="source" name="mmiperf/lwip/mmiperf_tcp_server.c" condition="require MM_IoT mmLwIP condition"/>
          <file category="source" name="mmiperf/lwip/mmiperf_udp_client.c" condition="require MM_IoT mmLwIP condition"/>
          <file category="source" name="mmiperf/lwip/mmiperf_udp_server.c" condition="require MM_IoT mmLwIP condition"/>
